# --- Configurações do Banco de Dados ---
# DB_HOST e DB_PORT são hardcoded no docker-compose.yml (db:3306)
DB_TYPE=mysql
DB_NAME=fluig
DB_USER=fluig
DB_PASSWORD=fluig

# --- Configurações de Performance (JVM) ---
# Runtime: standalone.conf usa FLUIG_SERVER_MEMORY_MIN/MAX (passados via docker-compose)
# Installer: server_memory_* são obrigatórios pelo validator mas não afetam o runtime
JVM_MAX_HEAP=4096
JVM_MIN_HEAP=2048
JVM_MAX_METASPACE=1024
JVM_MIN_METASPACE=512

# --- Pools ---
# Runtime: standalone.xml usa FLUIG_CONFIG_DATABASE_*_POOL_SIZE (passados via docker-compose)
# Installer: server_pool_* e db_*PoolSize são obrigatórios pelo validator
POOL_EJB=20
POOL_HTTP=200
POOL_MDB=20
POOL_DS_MAX=100
POOL_DS_MIN=10

# --- Configurações do Fluig ---
FLUIG_INSTALL_PATH=/opt/totvs/fluig
# false   = boot normal (sem instalação)
# update  = aplica patch/atualização mantendo dados do volume
# install = instalação limpa (apaga volume e reinstala do zero)
FLUIG_UPDATE=false

# --- Módulos (true/false) ---
INSTALL_SOLR=true
INSTALL_NODE=true

# --- Licenciamento ---
LS_HOST=127.0.0.1
LS_PORT=5555

# --- Portas Expostas ---
PORT_APP=8080
PORT_SSL=8443
PORT_SOLR=8983
PORT_REALTIME=8888
PORT_CHAT=7070
PORT_DB=3306

# --- Caminhos locais ---
INSTALLER_PATH=../installer-package
SCRIPTS_PATH=./scripts

# --- E-mail (SMTP / Mailpit) ---
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_SENDER=fluig@localhost
EMAIL_AUTH=false
EMAIL_SSL=false
EMAIL_TLS=false
PORT_MAIL_SMTP=1025
PORT_MAIL_UI=8025

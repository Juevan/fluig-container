# Banco de Dados
DB_TYPE=mysql
DB_HOST=db
DB_PORT=3306
DB_NAME=fluig
DB_USER=fluig
DB_PASSWORD=fluig
POOL_DS_MIN=10
POOL_DS_MAX=100

# JVM
JVM_MIN_HEAP=2048
JVM_MAX_HEAP=4096
POOL_EJB=20

# Serviços
INSTALL_SOLR=true
INSTALL_NODE=true
ENABLE_MAIL=true

# Portas (Host)
PORT_APP=8080
PORT_SSL=8443
PORT_DB=3306
PORT_SOLR=8983
PORT_REALTIME=8888
PORT_CHAT=7070
PORT_MAIL_UI=8025

# Controle de Atualização (false, install, update)
FLUIG_UPDATE=false

# License Server
LS_HOST=127.0.0.1
LS_PORT=5555